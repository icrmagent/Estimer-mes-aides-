# .env.deploy.example — copier en .env.deploy (gitignoré) pour scripts/deploy.{ps1,sh}

# DB Supabase (pooler session port 5432 obligatoire pour migrations)
DIRECT_URL=postgresql://postgres.zxkshqviyzjigadruody:****@aws-1-eu-north-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.zxkshqviyzjigadruody:****@aws-1-eu-north-1.pooler.supabase.com:6543/postgres

# Railway (Project Settings → Tokens)
RAILWAY_TOKEN=

# Vercel (vercel.com/account/tokens)
VERCEL_TOKEN=

# URL backend prod (utilisé pour le healthcheck post-deploy)
BACKEND_URL=https://estimer-mes-aides-production.up.railway.app
