# URL du backend API (requis)
VITE_BACKEND_URL=http://localhost:3000

# URL du CRM externe (optionnel — si vide, simulation activée)
VITE_CRM_URL=

# JWT CRM pré-configuré (optionnel — sinon saisie manuelle dans l'interface)
# Générer avec : cd src/backend && node scripts/generate-crm-jwt.js
VITE_CRM_JWT=
