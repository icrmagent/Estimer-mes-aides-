# ─── Base de données PostgreSQL (Supabase) ────────────────────────────────────
# connection_limit=10 configures the Prisma connection pool (task 27.5)
# Adjust based on your Supabase plan (free tier: max 15 connections)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.zxkshqviyzjigadruody.supabase.co:5432/postgres?connection_limit=10&pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.zxkshqviyzjigadruody.supabase.co:5432/postgres"

# ─── Auth & API Keys ──────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET="votre-jwt-secret-minimum-32-caracteres"
API_KEY_MOBILE="ema_mobile_xxxxxxxxxxxxxxxxxxxx"
API_KEY_CRM="ema_crm_xxxxxxxxxxxxxxxxxxxx"

# ─── Pusher WebSocket (V2) ────────────────────────────────────────────────────
# Créer un compte sur https://pusher.com et créer une app Channels
PUSHER_APP_ID="your_pusher_app_id"
PUSHER_KEY="your_pusher_key"
PUSHER_SECRET="your_pusher_secret"
PUSHER_CLUSTER="eu"

# ─── SuperAdmin initial (V2) ──────────────────────────────────────────────────
# Utilisé par le script de seed pour créer le premier SuperAdmin
SUPERADMIN_EMAIL="admin@estimer-mes-aides.fr"
SUPERADMIN_PASSWORD_TEMP="ChangeMe2026!"

# ─── CRM externe (V2 — partage asynchrone) ───────────────────────────────────
CRM_API_URL="https://app-web-abondance-dev-webapi.azurewebsites.net"
CRM_API_KEY="<JWT Bearer token I-CRM — à renouveler à l'expiration>"
CRM_USER_ID="1"

# ─── Redis (required in production — ADR-3 fail-secure caching) ──────────────
# Used for JWT blacklist, brute force protection, and response caching
REDIS_URL="redis://localhost:6379"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (required)
CORS_ALLOWED_ORIGINS="https://estimer-mes-aides.vercel.app,https://estimer-mes-aides-wjp3.vercel.app"

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
