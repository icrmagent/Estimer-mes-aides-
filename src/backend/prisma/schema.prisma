generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── V1 models (conservés, rétrocompatibles) ────────────────────────────────

model Configuration {
  id             Int      @id @default(autoincrement())
  formDefinition Json
  version        String
  updatedAt      DateTime @updatedAt

  @@map("configurations")
}

model Submission {
  id             String            @id @default(uuid())
  createdAt      DateTime          @default(now())
  configVersion  String
  synced         Boolean           @default(false)
  syncedAt       DateTime?
  crmProjectId   String?
  borneId        String? // NOUVEAU — nullable, rétrocompat V1
  borne          Borne?            @relation(fields: [borneId], references: [id])
  values         SubmissionValue[]
  enregistrement Enregistrement? // NOUVEAU — lien vers le modèle V2

  @@index([synced, createdAt])
  @@map("submissions")
}

model SubmissionValue {
  id           Int        @id @default(autoincrement())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldId      Int
  value        String

  @@index([submissionId])
  @@index([fieldId])
  @@map("submission_values")
}

// ─── V2 models ───────────────────────────────────────────────────────────────

model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

model AdminBorne {
  id            String   @id @default(uuid())
  nom           String
  prenom        String
  email         String   @unique
  passwordHash  String
  raisonSociale String
  siret         String
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bornes        Borne[]

  @@map("admin_bornes")
}

model Borne {
  id              String           @id @default(uuid())
  idBorne         String           @unique
  langueDefaut    String           @default("fr")
  adresse         String
  commercant      String?
  regie           String?
  installateur    String?
  canalTransmission String?
  statut          String           @default("actif")
  formulaireId    String?
  formulaire      Formulaire?      @relation(fields: [formulaireId], references: [id])
  adminBorneId    String?
  adminBorne      AdminBorne?      @relation(fields: [adminBorneId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  submissions     Submission[]
  enregistrements Enregistrement[]
  canaux          Canal[]

  @@index([statut])
  @@index([adminBorneId])
  @@index([deletedAt])
  @@map("bornes")
}

model Formulaire {
  id                   String               @id @default(uuid())
  label                String
  version              String               @default("1.0.0")
  statut               String               @default("brouillon")
  dureeRetourAccueil   Int                  @default(30)
  annulationInactivite Int                  @default(120)
  pageDebutConfig      Json
  pageFinConfig        Json
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  questions            Question[]
  bornes               Borne[]
  enregistrements      Enregistrement[]
  versions             FormulaireVersion[]

  @@index([statut])
  @@index([deletedAt])
  @@map("formulaires")
}

model FormulaireVersion {
  id           String     @id @default(uuid())
  formulaireId String
  version      String     // semver e.g. "2.1.0"
  snapshot     Json       // full formulaire JSON at this version
  changedBy    String     // superAdminId
  createdAt    DateTime   @default(now())
  formulaire   Formulaire @relation(fields: [formulaireId], references: [id])

  @@index([formulaireId, createdAt])
  @@map("formulaire_versions")
}

model Question {
  id              String                  @id @default(uuid())
  formulaireId    String
  formulaire      Formulaire              @relation(fields: [formulaireId], references: [id], onDelete: Cascade)
  libelleQuestion Json
  typeOption      String
  options         Json?
  orderPage       Int
  ordreDansPage   Int                     @default(0)
  obligatoire     Boolean                 @default(false)
  paragrapheInfo  Json?
  crmFieldIds     Json?
  categorieId     String?
  categorie       CategorieQuestion?      @relation(fields: [categorieId], references: [id])
  sousCategorieId String?
  sousCategorie   SousCategorieQuestion?  @relation(fields: [sousCategorieId], references: [id])
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  reponses        EnregistrementReponse[]

  @@index([formulaireId, orderPage])
  @@index([formulaireId, orderPage, ordreDansPage])
  @@index([categorieId])
  @@index([sousCategorieId])
  @@map("questions")
}

model CategorieQuestion {
  id              String                  @id @default(uuid())
  nom             String                  @unique
  sousCategories  SousCategorieQuestion[]
  questions       Question[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@map("categories_question")
}

model SousCategorieQuestion {
  id              String                  @id @default(uuid())
  nom             String
  categorieId     String
  categorie       CategorieQuestion       @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  questions       Question[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([categorieId])
  @@map("sous_categories_question")
}

model Enregistrement {
  id                 String                  @id @default(uuid())
  borneId            String
  borne              Borne                   @relation(fields: [borneId], references: [id])
  formulaireId       String
  formulaire         Formulaire              @relation(fields: [formulaireId], references: [id])
  formulaireVersion  String                  @default("1.0.0")
  langueUtilisee     String                  @default("fr")
  statutPartage      String                  @default("en_attente")
  tentatives         Int                     @default(0)
  derniereErreur     String?
  partageAt          DateTime?
  submissionId       String?                 @unique
  submission         Submission?             @relation(fields: [submissionId], references: [id])
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?
  reponses           EnregistrementReponse[]
  partageJobs        PartageJob[]

  @@index([createdAt])
  @@index([borneId, createdAt])
  @@index([statutPartage])
  @@index([deletedAt])
  @@map("enregistrements")
}

model EnregistrementReponse {
  id               Int            @id @default(autoincrement())
  enregistrementId String
  enregistrement   Enregistrement @relation(fields: [enregistrementId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question       @relation(fields: [questionId], references: [id])
  valeur           String
  legacyFieldId    Boolean        @default(false) // true = fieldId not in approved CRM list (ADR-7)

  @@index([enregistrementId])
  @@map("enregistrement_reponses")
}

model PartageJob {
  id               String    @id @default(uuid())
  enregistrementId String
  enregistrement   Enregistrement @relation(fields: [enregistrementId], references: [id], onDelete: Cascade)
  statut           String    @default("en_attente")
  tentatives       Int       @default(0)
  prochainEssai    DateTime?
  erreur           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([statut, prochainEssai])
  @@index([enregistrementId])
  @@map("partage_jobs")
}

// ─── Canal models ────────────────────────────────────────────────────────────

model Canal {
  id          String   @id @default(uuid())
  label       String
  apiUrl      String
  apiKey      String
  token       String
  borneId     String
  borne       Borne    @relation(fields: [borneId], references: [id], onDelete: Cascade)
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([borneId])
  @@map("canaux")
}

// ─── Security models ──────────────────────────────────────────────────────────

// Refresh tokens (DB-persisted for rotation/revocation)
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  userType  String    // 'superadmin' | 'adminborne'
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, userType])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// JWT blacklist — fast-path check for revoked access tokens
model RevokedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime
  revokedAt DateTime @default(now())

  @@index([expiresAt])
  @@map("revoked_tokens")
}

// Brute force protection — DB fallback when Redis is unavailable (ADR-3)
model LoginAttempt {
  id          String    @id @default(uuid())
  ip          String    @unique
  attempts    Int       @default(0)
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([ip])
  @@index([lockedUntil])
  @@map("login_attempts")
}
